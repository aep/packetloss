---
import Layout from '../../components/Layout.astro';
import Grid from '../../components/Grid.astro';
import { getCountries, getOverview } from '../../lib/data';

export function getStaticPaths() {
  return getCountries().countries.map((c) => ({ params: { country: c.code } }));
}

const { country } = Astro.params;
const ov = getOverview(country!);
---

<Layout title={`${ov.countryName} ranking`} activeCountry={country}>
  <h1>{ov.countryName}</h1>
  <p class="sub">Transit / ISP reachability to top destinations · generated {ov.generatedAt}</p>
  <Grid overview={ov} country={country!} />
  <p slot="footer">
    <strong>Score</strong> is an absolute 0–10 grade per destination from a fixed
    latency + loss + jitter curve (10 ≈ near-perfect), peer-independent and comparable
    across countries. A provider's score averages its destinations and is reduced by the
    share of red destinations. <strong>Cell colour</strong> comes from that same score via
    fixed thresholds, so red means genuinely poor. Measurements from RIPE Atlas.
  </p>
</Layout>
