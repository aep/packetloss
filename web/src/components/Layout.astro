---
import '../styles/global.css';
import { getCountries } from '../lib/data';

interface Props {
  title: string;
  activeCountry?: string;
  activePage?: 'faq' | 'imprint';
}
const { title, activeCountry, activePage } = Astro.props;
const countries = getCountries().countries;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · PacketLoss</title>
  </head>
  <body>
    <header class="site-header">
      <a href="/" class="brand">packet<span>loss</span></a>
      <nav class="countries">
        {countries.map((c) => (
          <a href={`/${c.code}/`} class={c.code === activeCountry ? 'active' : ''}>
            {c.name}
          </a>
        ))}
        <a href="/faq/" class={activePage === 'faq' ? 'active' : ''}>FAQ</a>
        <a href="/imprint/" class={activePage === 'imprint' ? 'active' : ''}>Imprint</a>
        <a href="https://github.com/aep/packetloss" target="_blank" rel="noopener">GitHub</a>
      </nav>
    </header>
    <main><slot /></main>
    {Astro.slots.has('footer') && (
      <footer class="site-footer">
        <slot name="footer" />
      </footer>
    )}
  </body>
</html>
